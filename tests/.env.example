# open-stock-data 测试环境变量示例
# 复制此文件为 .env 并填入你的 API keys

# Tushare API token (可选，用于A股高级数据)
# 注册地址: https://tushare.pro/register
TUSHARE_TOKEN=your_tushare_token_here

# Alpha Vantage API key (可选，用于美股新闻和技术指标)
# 注册地址: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# TickFlow API key (可选，用于全球市场实时行情)
# 注册地址: https://tickflow.org
TICKFLOW_API_KEY=your_tickflow_key_here

# 日志级别
LOG_LEVEL=INFO
